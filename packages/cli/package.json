{
  "name": "soma-cli",
  "version": "0.1.0",
  "description": "Soma CLI — drive the Programmable Assistant from the terminal.",
  "type": "module",
  "bin": {
    "soma": "./dist/index.mjs"
  },
  "files": ["dist", "install.sh"],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.mjs --target node",
    "build:binary": "bun run build:binary:darwin-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:linux-x64 && bun run build:binary:linux-arm64",
    "build:binary:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/soma-darwin-arm64",
    "build:binary:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/soma-darwin-x64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/soma-linux-x64",
    "build:binary:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/soma-linux-arm64",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "citty": "^0.1.6"
  }
}
