{
  "name": "@soma/spec",
  "version": "0.1.0",
  "private": true,
  "description": "TypeSpec source of truth for the Soma (Programmable Assistant) API → emits openapi/spec.json",
  "scripts": {
    "build": "tsp compile . && cp tsp-output/@typespec/openapi3/openapi/spec.json openapi/spec.json",
    "watch": "tsp compile . --watch"
  },
  "devDependencies": {
    "@typespec/compiler": "^0.62.0",
    "@typespec/http": "^0.62.0",
    "@typespec/openapi": "^0.62.0",
    "@typespec/openapi3": "^0.62.0",
    "@typespec/rest": "^0.62.0"
  }
}
