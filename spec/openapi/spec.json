        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "path",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "string",
                      "nullable": true,
                      "description": "base64-encoded bytes"
                    }
                  },
                  "required": [
                    "data"
                  ]
                }
              }
            }
          },
          "402": {
            "description": "Payment Required (metered key out of credits)"
          },
          "429": {
            "description": "Too Many Requests (rate limited)"
          }
