{
  "name": "workstation-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Workstation — a metered key gateway for AI services: keys, access control, credits, signup/topup, and reference capabilities (compute + storage) behind one typed contract that emits API + CLI + MCP.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "convex dev --until-success",
    "dev:local": "CONVEX_AGENT_MODE=anonymous convex dev",
    "dev:once": "CONVEX_AGENT_MODE=anonymous convex dev --once --typecheck enable",
    "setup": "bash scripts/setup.sh",
    "smoke": "bash scripts/smoke.sh",
    "verify": "bun run typecheck && bun test && bun run generate && git diff --exit-code spec/openapi docs/openapi && CONVEX_AGENT_MODE=anonymous convex dev --once --typecheck enable",
    "typecheck": "tsc --noEmit -p tsconfig.core.json",
    "test": "bun test",
    "generate": "bun scripts/gen-openapi.ts",
    "build:packages": "turbo run build",
    "web": "cd apps/web && bun run dev",
    "web:build": "cd apps/web && bun run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@vercel/sandbox": "^2.0.1",
    "convex": "^1.31.0",
    "stripe": "^22.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@types/bun": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tfcbot/workstation.git"
  },
  "homepage": "https://github.com/tfcbot/workstation#readme",
  "bugs": {
    "url": "https://github.com/tfcbot/workstation/issues"
  }
}
