{
  "name": "programmable-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Soma — a programmable body for an agent's brain. Six primitives (phone, email, wallet, computer, storage, todo) behind one opinionated API.",
  "type": "module",
  "workspaces": [
    "spec",
    "packages/*"
  ],
  "scripts": {
    "dev": "convex dev --until-success",
    "typecheck": "tsc --noEmit -p tsconfig.core.json",
    "test": "bun test",
    "spec:build": "bun --filter @soma/spec build",
    "generate": "bun run spec:build && bun --filter soma generate",
    "build:packages": "turbo run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "agentmail": "^0.5.3",
    "convex": "^1.31.0",
    "freestyle": "^0.1.52"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tfcbot/soma.git"
  },
  "homepage": "https://github.com/tfcbot/soma#readme",
  "bugs": {
    "url": "https://github.com/tfcbot/soma/issues"
  }
}
