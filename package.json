{
  "name": "workstation-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Workstation — a headless contract for agents that do work: five primitives (phone, email, wallet, computer, storage) behind one metered gateway.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "convex dev --until-success",
    "typecheck": "tsc --noEmit -p tsconfig.core.json",
    "test": "bun test",
    "generate": "bun scripts/gen-openapi.ts",
    "build:packages": "turbo run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "agentmail": "^0.5.3",
    "convex": "^1.31.0",
    "freestyle": "0.1.52",
    "stripe": "^22.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@types/bun": "latest",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tfcbot/workstation.git"
  },
  "homepage": "https://github.com/tfcbot/workstation#readme",
  "bugs": {
    "url": "https://github.com/tfcbot/workstation/issues"
  }
}
