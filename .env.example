# ─── Gateway (required) ───────────────────────────────────────────────────────
# The single API key that protects every endpoint. Send as: Authorization: Bearer <key>
# Anything without this key gets a 401. (Single-node: no per-client keys.)
GATEWAY_API_KEY=

# ─── Providers (all optional) ─────────────────────────────────────────────────
# Omit any of these and that primitive runs on its MOCK adapter.
# Set on the Convex deployment with:  npx convex env set NAME value

# Phone — AgentPhone (needs an agent id; live SMS requires A2P 10DLC registration)
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=

# Email — AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=

# Wallet — AgentCard (issues prepaid cards under one cardholder)
AGENTCARD_API_KEY=
AGENTCARD_CARDHOLDER_ID=

# Sandbox — Freestyle (VM + git: real compute, ffmpeg, no 5-min cap)
FREESTYLE_API_KEY=

# FileSystem — Archil disk backed by an R2 bucket (durable blobs + personal CDN).
# Writing an object to the bucket makes it visible on the Archil disk and servable at the CDN.
ARCHIL_DISK_ID=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=
# Public base for delivered assets (custom domain on the R2 bucket, or its r2.dev URL)
CDN_BASE_URL=
