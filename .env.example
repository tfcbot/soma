# ─── API keys ─────────────────────────────────────────────────────────────────
# There is NO single gateway key. The operator mints per-key accounts; each bearer key
# resolves to an account with a credit balance. Billing applies uniformly (no admin/free tier
# baked in — set per-op cost to 0, or mint a large balance, if you want free access). Mint one:
#   bunx convex run accounts:mintKey '{"label":"owner","creditsCents":100000}'
# (Returns the plaintext key once.) See SPEC §7.1 / §16.

# ─── Billing (optional) ───────────────────────────────────────────────────────
# Per-op credit costs live in core/domain/pricing.ts. To add credits to a key, call
#   bunx convex run accounts:grantCredits '{"accountId":"acc_…","amountCents":5000}'
# Stripe is the shipped reference rail. STRIPE_SECRET_KEY alone enables POST /v1/topup (Checkout)
# and POST /v1/topup/confirm (poll fulfillment — no webhook needed; good for testing). Add
# STRIPE_WEBHOOK_SECRET to also verify the automatic /webhooks/stripe handler (local dev: get a
# whsec_ from `stripe listen --forward-to <deploy>/webhooks/stripe`). Both paths credit idempotently
# via topups:creditOnce. Swap rails by replacing convex/payments.ts. Unset = top-ups disabled;
# grantCredits still works manually.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public URL of your deployed apps/web. Used for Stripe success/cancel redirects and
# the 402 topupUrl. Falls back to the deprecated WORKSTATION_TOPUP_URL if set.
WORKSTATION_LANDING_URL=
# Abuse protection (off unless set): max calls per (account, operation) per minute.
WORKSTATION_RATE_LIMIT_PER_MIN=

# ─── Providers (all optional) ─────────────────────────────────────────────────
# Omit any of these and that primitive runs on its MOCK adapter.
# Set on the Convex deployment with:  npx convex env set NAME value

# Phone — AgentPhone (needs an agent id; live SMS requires A2P 10DLC registration)
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=

# Email — AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=


# Computer — Vercel Sandbox (persistent microVM by name). For non-Vercel hosting (e.g. Convex)
# use the access-token triple below; on Vercel, an OIDC token is auto-handled by the SDK.
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=

# FileSystem — Cloudflare R2 (S3 API) for durable blobs + a CDN for public delivery.
# Writing an object public makes it servable at the CDN base URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=
# Public base for delivered assets (custom domain on the R2 bucket, or its r2.dev URL)
CDN_BASE_URL=
