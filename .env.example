# ─── API keys ─────────────────────────────────────────────────────────────────
# There is NO single gateway key. The operator mints per-key accounts; each bearer key
# resolves to an account with a credit balance. Billing applies uniformly (no admin/free tier
# baked in — set per-op cost to 0, or mint a large balance, if you want free access). Mint one:
#   bunx convex run accounts:mintKey '{"label":"owner","creditsCents":100000}'
# (Returns the plaintext key once.) See SPEC §7.1 / §16.

# ─── Billing (optional) ───────────────────────────────────────────────────────
# Per-op credit costs live in core/domain/pricing.ts. To add credits to a key, call
#   bunx convex run accounts:grantCredits '{"accountId":"acc_…","amountCents":5000}'
# Stripe is the shipped reference rail: set the keys below to enable POST /v1/topup (Checkout) +
# the /webhooks/stripe handler that credits the account via grantCredits. Swap it for another
# rail by replacing convex/payments.ts. Unset = top-ups disabled; grantCredits still works manually.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Link returned in a 402 / used as the Checkout return URL.
WORKSTATION_TOPUP_URL=
# Abuse protection (off unless set): max calls per (account, operation) per minute.
WORKSTATION_RATE_LIMIT_PER_MIN=

# ─── Providers (all optional) ─────────────────────────────────────────────────
# Omit any of these and that primitive runs on its MOCK adapter.
# Set on the Convex deployment with:  npx convex env set NAME value

# Phone — AgentPhone (needs an agent id; live SMS requires A2P 10DLC registration)
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=

# Email — AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=

# Wallet — AgentCard (issues prepaid cards under one cardholder)
AGENTCARD_API_KEY=
AGENTCARD_CARDHOLDER_ID=

# Sandbox — Freestyle (VM + git: real compute, ffmpeg, no 5-min cap)
FREESTYLE_API_KEY=

# FileSystem — Archil disk backed by an R2 bucket (durable blobs + personal CDN).
# Writing an object to the bucket makes it visible on the Archil disk and servable at the CDN.
ARCHIL_DISK_ID=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=
# Public base for delivered assets (custom domain on the R2 bucket, or its r2.dev URL)
CDN_BASE_URL=
